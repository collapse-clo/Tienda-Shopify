<div class="clp-brand">
  <div class="clp-brand__media">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 900 }}"
           alt="{{ section.settings.image.alt | escape }}"
           class="clp-brand__img" loading="lazy">
    {%- else -%}
      <div class="clp-brand__placeholder">
        <span>COLLAPSE</span>
      </div>
    {%- endif -%}
  </div>
  <div class="clp-brand__content">
    {%- if section.settings.label != blank -%}
      <p class="clp-brand__label">{{ section.settings.label }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="clp-brand__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <div class="clp-brand__text">{{ section.settings.text }}</div>
    {%- endif -%}
    {%- if section.settings.link_label != blank and section.settings.link != blank -%}
      <a href="{{ section.settings.link }}" class="clp-brand__link">
        {{ section.settings.link_label }} →
      </a>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
.clp-brand {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 520px;
}

.clp-brand__media { overflow: hidden; }
.clp-brand__img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  filter: grayscale(15%);
}
.clp-brand__placeholder {
  width: 100%; height: 100%; min-height: 520px;
  background: #111;
  display: flex; align-items: center; justify-content: center;
}
.clp-brand__placeholder span {
  font-family: 'Helvetica Neue', Helvetica, sans-serif;
  font-size: 1.2rem; letter-spacing: 0.4em;
  color: rgba(245,240,232,0.15); text-indent: 0.4em;
}

.clp-brand__content {
  display: flex; flex-direction: column; justify-content: center;
  padding: 64px 56px;
  background: #1A1A1A;
}

.clp-brand__label {
  font-size: 0.6rem; letter-spacing: 0.3em;
  color: rgba(245,240,232,0.45); text-transform: uppercase;
  margin: 0 0 20px;
}
.clp-brand__heading {
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  letter-spacing: 0.08em; font-weight: 400;
  color: #F5F0E8; text-transform: uppercase;
  margin: 0 0 24px; line-height: 1.15;
}
.clp-brand__text {
  font-size: 0.82rem; line-height: 2;
  color: rgba(245,240,232,0.65);
  letter-spacing: 0.04em; margin: 0 0 32px;
}
.clp-brand__link {
  font-size: 0.65rem; letter-spacing: 0.22em;
  text-transform: uppercase; color: #F5F0E8;
  border-bottom: 1px solid rgba(245,240,232,0.3);
  padding-bottom: 3px; width: fit-content;
  transition: border-color 0.25s;
}
.clp-brand__link:hover { border-color: #F5F0E8; }

@media (max-width: 768px) {
  .clp-brand { grid-template-columns: 1fr; }
  .clp-brand__content { padding: 48px 28px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Sobre la marca",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Imagen" },
    { "type": "text", "id": "label", "label": "Etiqueta pequeña", "default": "Sobre nosotros" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Construido para lo que viene." },
    { "type": "richtext", "id": "text", "label": "Texto", "default": "<p>Collapse no es una marca de tendencias. Es ropa construida para durar más allá de las temporadas. Cada pieza tiene una razón. Cada decisión de diseño, una intención.</p><p>Sin ruido. Sin logo que pida atención. Solo construcción.</p>" },
    { "type": "text", "id": "link_label", "label": "Texto del enlace", "default": "Leer el manifiesto" },
    { "type": "url", "id": "link", "label": "Enlace" }
  ],
  "presets": [{ "name": "Sobre la marca" }]
}
{% endschema %}
