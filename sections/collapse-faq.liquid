<div class="clp-faq">
  <div class="clp-faq__inner">
    <p class="clp-faq__label">{{ section.settings.label }}</p>
    <h2 class="clp-faq__heading">{{ section.settings.heading }}</h2>

    <div class="clp-faq__list">
      {%- for i in (1..8) -%}
        {%- liquid
          case i
          when 1
            assign q = section.settings.q1
            assign a = section.settings.a1
          when 2
            assign q = section.settings.q2
            assign a = section.settings.a2
          when 3
            assign q = section.settings.q3
            assign a = section.settings.a3
          when 4
            assign q = section.settings.q4
            assign a = section.settings.a4
          when 5
            assign q = section.settings.q5
            assign a = section.settings.a5
          when 6
            assign q = section.settings.q6
            assign a = section.settings.a6
          when 7
            assign q = section.settings.q7
            assign a = section.settings.a7
          when 8
            assign q = section.settings.q8
            assign a = section.settings.a8
          endcase
        -%}
        {%- if q != blank and a != blank -%}
          <div class="clp-faq__item">
            <button class="clp-faq__q" aria-expanded="false">
              <span>{{ q }}</span>
              <span class="clp-faq__icon">+</span>
            </button>
            <div class="clp-faq__a" hidden>
              <p>{{ a }}</p>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
(function(){
  document.querySelectorAll('.clp-faq__q').forEach(function(btn){
    btn.addEventListener('click', function(){
      var item    = this.closest('.clp-faq__item');
      var answer  = item.querySelector('.clp-faq__a');
      var icon    = item.querySelector('.clp-faq__icon');
      var isOpen  = this.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll('.clp-faq__item').forEach(function(el){
        el.querySelector('.clp-faq__q').setAttribute('aria-expanded','false');
        el.querySelector('.clp-faq__a').hidden = true;
        el.querySelector('.clp-faq__icon').textContent = '+';
        el.classList.remove('open');
      });
      if (!isOpen) {
        this.setAttribute('aria-expanded','true');
        answer.hidden = false;
        icon.textContent = '−';
        item.classList.add('open');
      }
    });
  });
})();
</script>

{% stylesheet %}
.clp-faq {
  background: #1A1A1A;
  padding: 72px 40px;
  border-top: 1px solid #2C2C2C;
}
.clp-faq__inner { max-width: 720px; margin: 0 auto; }

.clp-faq__label {
  font-size: 0.6rem; letter-spacing: 0.3em;
  text-transform: uppercase; color: rgba(245,240,232,0.4);
  margin: 0 0 16px;
}
.clp-faq__heading {
  font-size: clamp(1.4rem, 2.5vw, 2rem);
  font-weight: 400; letter-spacing: 0.1em;
  text-transform: uppercase; color: #F5F0E8;
  margin: 0 0 48px;
}

.clp-faq__item {
  border-bottom: 1px solid #2C2C2C;
}
.clp-faq__q {
  width: 100%; background: none; border: none; cursor: pointer;
  display: flex; justify-content: space-between; align-items: center;
  padding: 22px 0; text-align: left; gap: 16px;
  color: rgba(245,240,232,0.75);
  font-size: 0.78rem; letter-spacing: 0.1em;
  font-family: 'Helvetica Neue', Helvetica, sans-serif;
  transition: color 0.2s;
}
.clp-faq__q:hover,
.clp-faq__item.open .clp-faq__q { color: #F5F0E8; }

.clp-faq__icon {
  font-size: 1.1rem; line-height: 1;
  color: rgba(245,240,232,0.35); flex-shrink: 0;
  transition: color 0.2s;
}
.clp-faq__item.open .clp-faq__icon { color: #F5F0E8; }

.clp-faq__a {
  padding: 0 0 22px;
}
.clp-faq__a p {
  font-size: 0.76rem; line-height: 2;
  color: rgba(245,240,232,0.5); letter-spacing: 0.04em;
  margin: 0;
}

@media (max-width: 768px) {
  .clp-faq { padding: 56px 24px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Preguntas frecuentes",
  "settings": [
    { "type": "text", "id": "label",   "label": "Etiqueta", "default": "FAQ" },
    { "type": "text", "id": "heading", "label": "Título",   "default": "Preguntas frecuentes" },
    { "type": "text",     "id": "q1", "label": "Pregunta 1", "default": "¿Cuánto tarda el envío?" },
    { "type": "textarea", "id": "a1", "label": "Respuesta 1","default": "Los pedidos se envían en 24-48h laborables para España peninsular. Recibirás un email de confirmación con el número de seguimiento." },
    { "type": "text",     "id": "q2", "label": "Pregunta 2", "default": "¿Puedo devolver una prenda?" },
    { "type": "textarea", "id": "a2", "label": "Respuesta 2","default": "Sí. Tienes 14 días desde la recepción del pedido para devolver cualquier prenda sin usar y con las etiquetas originales. Escríbenos a nuestro email y te gestionamos el proceso." },
    { "type": "text",     "id": "q3", "label": "Pregunta 3", "default": "¿Hay restock de las prendas agotadas?" },
    { "type": "textarea", "id": "a3", "label": "Respuesta 3","default": "No. Cada fase de Collapse es una producción limitada sin restock. Cuando se acaba, se acaba. Para ser el primero en enterarte de nuevos drops, suscríbete a nuestra lista." },
    { "type": "text",     "id": "q4", "label": "Pregunta 4", "default": "¿Qué talla me pongo?" },
    { "type": "textarea", "id": "a4", "label": "Respuesta 4","default": "Nuestras prendas tienen un corte oversized. Si dudas entre dos tallas, te recomendamos la menor. Consulta la guía de tallas más arriba o escríbenos con tus medidas." },
    { "type": "text",     "id": "q5", "label": "Pregunta 5", "default": "¿De qué están hechas las prendas?" },
    { "type": "textarea", "id": "a5", "label": "Respuesta 5","default": "100% algodón de 380g de gramaje. Material pesado, tacto denso y resistente. Diseñado para durar más allá de las temporadas." },
    { "type": "text",     "id": "q6", "label": "Pregunta 6", "default": "¿Cómo cuido la prenda?" },
    { "type": "textarea", "id": "a6", "label": "Respuesta 6","default": "Lavar a 30°C del revés, sin secadora. Planchar a temperatura media del revés. Para conservar el color y la forma, evita el lavado frecuente innecesario." },
    { "type": "text",     "id": "q7", "label": "Pregunta 7", "default": "¿Envíais fuera de España?" },
    { "type": "textarea", "id": "a7", "label": "Respuesta 7","default": "Por ahora los envíos son solo a España peninsular. Si tienes interés en recibir un pedido fuera de España, escríbenos y valoramos opciones." },
    { "type": "text",     "id": "q8", "label": "Pregunta 8", "default": "" },
    { "type": "textarea", "id": "a8", "label": "Respuesta 8","default": "" }
  ],
  "presets": [{ "name": "Preguntas frecuentes" }]
}
{% endschema %}
