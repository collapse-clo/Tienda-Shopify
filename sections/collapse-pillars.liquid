<div class="clp-pillars">
  <div class="clp-pillars__grid">
    {%- for i in (1..3) -%}
      {%- liquid
        case i
        when 1
          assign icon    = section.settings.icon_1
          assign title   = section.settings.title_1
          assign text    = section.settings.text_1
        when 2
          assign icon    = section.settings.icon_2
          assign title   = section.settings.title_2
          assign text    = section.settings.text_2
        when 3
          assign icon    = section.settings.icon_3
          assign title   = section.settings.title_3
          assign text    = section.settings.text_3
        endcase
      -%}
      <div class="clp-pillar">
        {%- if icon != blank -%}
          <span class="clp-pillar__icon">{{ icon }}</span>
        {%- endif -%}
        {%- if title != blank -%}
          <h3 class="clp-pillar__title">{{ title }}</h3>
        {%- endif -%}
        {%- if text != blank -%}
          <p class="clp-pillar__text">{{ text }}</p>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
.clp-pillars {
  background: #1A1A1A;
  padding: 64px 40px;
  border-top: 1px solid #2C2C2C;
  border-bottom: 1px solid #2C2C2C;
}

.clp-pillars__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  max-width: 1200px;
  margin: 0 auto;
}

.clp-pillar {
  padding: 40px 48px;
  border-right: 1px solid #2C2C2C;
  text-align: left;
}
.clp-pillar:last-child { border-right: none; }

.clp-pillar__icon {
  display: block;
  font-size: 1.4rem;
  margin-bottom: 20px;
  opacity: 0.6;
}

.clp-pillar__title {
  font-size: 0.72rem;
  letter-spacing: 0.22em;
  font-weight: 400;
  text-transform: uppercase;
  color: #F5F0E8;
  margin: 0 0 14px;
}

.clp-pillar__text {
  font-size: 0.78rem;
  line-height: 1.9;
  color: rgba(245,240,232,0.5);
  letter-spacing: 0.03em;
  margin: 0;
}

@media (max-width: 768px) {
  .clp-pillars { padding: 48px 24px; }
  .clp-pillars__grid { grid-template-columns: 1fr; }
  .clp-pillar { border-right: none; border-bottom: 1px solid #2C2C2C; padding: 32px 8px; }
  .clp-pillar:last-child { border-bottom: none; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Pilares de marca",
  "settings": [
    { "type": "text", "id": "icon_1",  "label": "Icono 1 (emoji o símbolo)", "default": "◈" },
    { "type": "text", "id": "title_1", "label": "Título 1", "default": "100% Algodón 380g" },
    { "type": "text", "id": "text_1",  "label": "Texto 1",  "default": "Gramaje pesado, tacto denso. Diseñado para aguantar." },
    { "type": "text", "id": "icon_2",  "label": "Icono 2 (emoji o símbolo)", "default": "◻" },
    { "type": "text", "id": "title_2", "label": "Título 2", "default": "Producción limitada" },
    { "type": "text", "id": "text_2",  "label": "Texto 2",  "default": "Sin restock. Cuando se acaba, se acaba." },
    { "type": "text", "id": "icon_3",  "label": "Icono 3 (emoji o símbolo)", "default": "→" },
    { "type": "text", "id": "title_3", "label": "Título 3", "default": "Envío 24-48h" },
    { "type": "text", "id": "text_3",  "label": "Texto 3",  "default": "España peninsular. Gratis a partir de 80€." }
  ],
  "presets": [{ "name": "Pilares de marca" }]
}
{% endschema %}
