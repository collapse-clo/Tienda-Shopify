<div class="clp-sizes">
  <div class="clp-sizes__inner">
    <p class="clp-sizes__label">{{ section.settings.label }}</p>
    <h2 class="clp-sizes__heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.note != blank -%}
      <p class="clp-sizes__note">{{ section.settings.note }}</p>
    {%- endif -%}

    <div class="clp-sizes__table-wrap">
      <table class="clp-sizes__table">
        <thead>
          <tr>
            <th></th>
            <th>S</th>
            <th>M</th>
            <th>L</th>
            <th>XL</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="clp-sizes__row-label">Pecho</td>
            <td>96 cm</td><td>100 cm</td><td>104 cm</td><td>108 cm</td>
          </tr>
          <tr>
            <td class="clp-sizes__row-label">Largo</td>
            <td>68 cm</td><td>70 cm</td><td>72 cm</td><td>74 cm</td>
          </tr>
          <tr>
            <td class="clp-sizes__row-label">Hombros</td>
            <td>44 cm</td><td>46 cm</td><td>48 cm</td><td>50 cm</td>
          </tr>
          <tr>
            <td class="clp-sizes__row-label">Manga</td>
            <td>62 cm</td><td>64 cm</td><td>66 cm</td><td>68 cm</td>
          </tr>
        </tbody>
      </table>
    </div>

    {%- if section.settings.tip != blank -%}
      <p class="clp-sizes__tip">{{ section.settings.tip }}</p>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
.clp-sizes {
  background: #1A1A1A;
  padding: 72px 40px;
}
.clp-sizes__inner {
  max-width: 720px;
  margin: 0 auto;
}

.clp-sizes__label {
  font-size: 0.6rem; letter-spacing: 0.3em;
  text-transform: uppercase; color: rgba(245,240,232,0.4);
  margin: 0 0 16px;
}
.clp-sizes__heading {
  font-size: clamp(1.4rem, 2.5vw, 2rem);
  font-weight: 400; letter-spacing: 0.1em;
  text-transform: uppercase; color: #F5F0E8;
  margin: 0 0 12px;
}
.clp-sizes__note {
  font-size: 0.72rem; color: rgba(245,240,232,0.45);
  letter-spacing: 0.04em; margin: 0 0 40px; line-height: 1.8;
}

.clp-sizes__table-wrap { overflow-x: auto; }
.clp-sizes__table {
  width: 100%; border-collapse: collapse;
  font-size: 0.72rem; letter-spacing: 0.08em;
}
.clp-sizes__table th,
.clp-sizes__table td {
  padding: 16px 20px;
  text-align: center;
  border-bottom: 1px solid #2C2C2C;
  color: rgba(245,240,232,0.7);
}
.clp-sizes__table thead th {
  color: #F5F0E8; font-weight: 400;
  letter-spacing: 0.2em; text-transform: uppercase;
  font-size: 0.65rem; border-bottom: 1px solid rgba(245,240,232,0.2);
}
.clp-sizes__table thead th:first-child { text-align: left; }
.clp-sizes__row-label {
  text-align: left !important;
  color: rgba(245,240,232,0.45) !important;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  font-size: 0.62rem !important;
}
.clp-sizes__table tr:last-child td { border-bottom: none; }
.clp-sizes__table tr:hover td { background: rgba(245,240,232,0.03); }

.clp-sizes__tip {
  font-size: 0.68rem; letter-spacing: 0.06em;
  color: rgba(245,240,232,0.35); margin: 28px 0 0;
  line-height: 1.8; font-style: italic;
}

@media (max-width: 768px) {
  .clp-sizes { padding: 56px 24px; }
  .clp-sizes__table th, .clp-sizes__table td { padding: 12px 14px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Guía de tallas",
  "settings": [
    { "type": "text",     "id": "label",   "label": "Etiqueta",  "default": "Medidas" },
    { "type": "text",     "id": "heading",  "label": "Título",    "default": "Guía de tallas" },
    { "type": "textarea", "id": "note",     "label": "Nota",      "default": "Nuestras prendas tienen un corte oversized. Si dudas entre dos tallas, elige la menor." },
    { "type": "textarea", "id": "tip",      "label": "Consejo",   "default": "Medidas aproximadas. Para más información escríbenos antes de comprar." }
  ],
  "presets": [{ "name": "Guía de tallas" }]
}
{% endschema %}
