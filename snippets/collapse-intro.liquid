{%- unless request.design_mode -%}
{%- if settings.logo != blank -%}
  {%- assign logo_src = settings.logo | image_url: width: 800 -%}
{%- endif -%}

<style>
/* ============================================================
   COLLAPSE — Cinematic Hacker Intro
   ============================================================ */
#clp-i {
  position: fixed; inset: 0; z-index: 999999;
  background: #000; overflow: hidden;
  font-family: 'Courier New', Courier, monospace;
  display: flex; align-items: center; justify-content: center;
}

/* Canvas fondo */
#clp-c { position: absolute; inset: 0; z-index: 1; }

/* Scanlines */
#clp-i::before {
  content: ''; position: absolute; inset: 0; z-index: 12; pointer-events: none;
  background: repeating-linear-gradient(
    0deg, transparent, transparent 2px,
    rgba(0,0,0,0.13) 2px, rgba(0,0,0,0.13) 4px
  );
}

/* Viñeta CRT */
#clp-i::after {
  content: ''; position: absolute; inset: 0; z-index: 13; pointer-events: none;
  background: radial-gradient(ellipse at 50% 50%, transparent 38%, rgba(0,0,0,0.88) 100%);
}

/* Flash overlay */
#clp-fl {
  position: absolute; inset: 0; z-index: 25; pointer-events: none;
  opacity: 0;
}

/* ── Logo wrap ── */
#clp-lw {
  position: relative; z-index: 15;
  opacity: 0;
  will-change: transform, opacity;
}

/* Logo layers */
.clp-ll {
  display: block;
  height: 80px; width: auto; max-width: 280px;
  object-fit: contain;
}

#clp-lg-r, #clp-lg-b {
  position: absolute; top: 0; left: 0;
  opacity: 0; pointer-events: none;
  mix-blend-mode: screen;
}

/* Aberración cromática normal */
.chr #clp-lg-r { opacity: 0.65; transform: translate(-4px, 0);  filter: hue-rotate(330deg) saturate(4); }
.chr #clp-lg-b { opacity: 0.65; transform: translate( 4px, 0);  filter: hue-rotate(210deg) saturate(4); }
/* Aberración intensa fase 4 */
.chr-x #clp-lg-r { opacity: 0.9; transform: translate(-12px, 2px);  filter: hue-rotate(330deg) saturate(6); }
.chr-x #clp-lg-b { opacity: 0.9; transform: translate( 12px,-2px);  filter: hue-rotate(210deg) saturate(6); }

/* Línea de escáner */
#clp-sl {
  position: absolute; left: -24px; right: -24px; height: 2px;
  background: linear-gradient(to right, transparent, #00FF41 20%, #00FF41 80%, transparent);
  box-shadow: 0 0 8px #00FF41, 0 0 18px #00FF41;
  top: 0; opacity: 0; pointer-events: none;
}
#clp-sl.on { opacity: 1; animation: clp-sweep 0.55s ease-in-out infinite alternate; }
@keyframes clp-sweep { from { top: -10px; } to { top: calc(80px + 10px); } }

/* ── HUD ── */
#clp-hud-t, #clp-hud-b {
  position: absolute; left: 50%; transform: translateX(-50%);
  width: 320px; text-align: center;
  display: none; pointer-events: none;
}
#clp-hud-t { top: -64px; }
#clp-hud-b { top: 96px; }

.clp-brk {
  font-size: 10px; letter-spacing: 0.14em; color: #00FF41;
  animation: clp-flk 0.18s step-start infinite;
}
@keyframes clp-flk { 50% { opacity: 0.3; } }

#clp-hex {
  font-size: 9px; letter-spacing: 0.08em;
  color: rgba(0,255,65,0.55); margin-top: 5px;
}

#clp-pct {
  font-size: 30px; font-weight: 700; letter-spacing: 0.1em;
  color: #00FF41; margin: 6px 0 4px;
  text-shadow: 0 0 12px #00FF41, 0 0 24px #00FF41;
}

#clp-stat {
  font-size: 9px; letter-spacing: 0.22em; color: rgba(0,255,65,0.8);
  animation: clp-flk 0.45s step-start infinite;
}

/* Skip */
#clp-sk {
  position: absolute; bottom: 22px; right: 26px; z-index: 30;
  background: transparent; border: 1px solid rgba(0,255,65,0.28);
  color: rgba(0,255,65,0.45); font-family: 'Courier New', monospace;
  font-size: 9px; letter-spacing: 0.22em; padding: 5px 13px;
  cursor: pointer; transition: all 0.18s;
}
#clp-sk:hover { border-color: #00FF41; color: #00FF41; box-shadow: 0 0 8px rgba(0,255,65,0.35); }
</style>

<div id="clp-i">
  <canvas id="clp-c"></canvas>
  <div id="clp-fl"></div>

  <div id="clp-lw">
    {%- if settings.logo != blank -%}
      <img id="clp-lg-r"    src="{{ logo_src }}" class="clp-ll" alt="">
      <img id="clp-lg-b"    src="{{ logo_src }}" class="clp-ll" alt="">
      <img id="clp-lg-main" src="{{ logo_src }}" class="clp-ll" alt="{{ shop.name }}">
    {%- else -%}
      <div id="clp-lg-r"    style="display:none"></div>
      <div id="clp-lg-b"    style="display:none"></div>
      <div id="clp-lg-main" style="color:#00FF41;font-size:2rem;letter-spacing:0.5em;text-indent:0.5em;text-shadow:0 0 18px #00FF41">
        {{ shop.name | upcase }}
      </div>
    {%- endif -%}
    <div id="clp-sl"></div>
    <div id="clp-hud-t">
      <div class="clp-brk">[ ACCESSING... ]</div>
      <div id="clp-hex">0xFF00A1</div>
    </div>
    <div id="clp-hud-b">
      <div id="clp-pct">0%</div>
      <div id="clp-stat">INITIALIZING...</div>
      <div class="clp-brk" style="margin-top:4px">[ SYSTEM... ]</div>
    </div>
  </div>

  <button id="clp-sk">SKIP ▶</button>
</div>

<script>
(function () {
  /* ── early exit if already seen ── */
  if (sessionStorage.getItem('clp-intro')) {
    var el = document.getElementById('clp-i');
    if (el) el.remove();
    return;
  }

  var intro  = document.getElementById('clp-i');
  var canvas = document.getElementById('clp-c');
  var ctx    = canvas.getContext('2d');
  var flash  = document.getElementById('clp-fl');
  var lw     = document.getElementById('clp-lw');
  var sl     = document.getElementById('clp-sl');
  var hudT   = document.getElementById('clp-hud-t');
  var hudB   = document.getElementById('clp-hud-b');
  var hexEl  = document.getElementById('clp-hex');
  var pctEl  = document.getElementById('clp-pct');
  var statEl = document.getElementById('clp-stat');
  var skip   = document.getElementById('clp-sk');

  /* ── Canvas sizing ── */
  function resize() { canvas.width = innerWidth; canvas.height = innerHeight; }
  resize();
  addEventListener('resize', resize);

  /* ── Character grid ── */
  var CH  = 'ABCDEF0123456789!@#%^&*<>/\\|[]{}アイウカキクCOLLAPSE';
  var CS  = 16;
  var cols, rows, grid;

  function buildGrid() {
    cols = Math.ceil(canvas.width  / CS) + 1;
    rows = Math.ceil(canvas.height / CS) + 1;
    grid = [];
    for (var r = 0; r < rows; r++) {
      grid[r] = [];
      for (var c = 0; c < cols; c++)
        grid[r][c] = { ch: rndCh(), a: Math.random() * 0.55 + 0.08 };
    }
  }
  function rndCh() { return CH[Math.floor(Math.random() * CH.length)]; }
  buildGrid();

  /* ── Particles (phase 4) ── */
  var pts = [];
  function spawnPts(n) {
    var cx = canvas.width / 2, cy = canvas.height / 2;
    for (var i = 0; i < n; i++) {
      var a = Math.random() * Math.PI * 2, spd = Math.random() * 12 + 4;
      pts.push({
        x: cx + (Math.random()-0.5)*160, y: cy + (Math.random()-0.5)*100,
        vx: Math.cos(a)*spd, vy: Math.sin(a)*spd,
        life: 1, sz: Math.floor(Math.random()*14)+7,
        ch: rndCh()
      });
    }
  }

  /* ── Render loops ── */
  function drawGrid() {
    ctx.fillStyle = 'rgba(0,0,0,0.07)';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.font = (CS-2) + 'px "Courier New"';

    for (var r = 0; r < rows; r++) {
      var ox = Math.random() < 0.007 ? (Math.random()-0.5)*50 : 0;
      for (var c = 0; c < cols; c++) {
        if (Math.random() < 0.055) { grid[r][c].ch = rndCh(); grid[r][c].a = Math.random()*0.55+0.08; }
        ctx.fillStyle = 'rgba(0,255,65,' + (grid[r][c].a * 0.5) + ')';
        ctx.fillText(grid[r][c].ch, c*CS + ox, r*CS + CS-2);
      }
    }
    /* Horizontal glitch bar */
    if (Math.random() < 0.07) {
      var gy = Math.floor(Math.random() * canvas.height);
      var gh = Math.floor(Math.random() * 3) + 1;
      try {
        var id = ctx.getImageData(0, gy, canvas.width, gh);
        ctx.putImageData(id, Math.floor((Math.random()-0.5)*50), gy);
      } catch(e) {}
    }
  }

  function drawPts() {
    pts = pts.filter(function(p){ return p.life > 0; });
    for (var i = 0; i < pts.length; i++) {
      var p = pts[i];
      p.x += p.vx; p.y += p.vy;
      p.vx *= 1.07; p.vy *= 1.07;
      p.life -= 0.022;
      ctx.fillStyle = 'rgba(0,255,65,' + Math.max(0,p.life).toFixed(2) + ')';
      ctx.font = p.sz + 'px "Courier New"';
      ctx.fillText(p.ch, p.x, p.y);
    }
  }

  /* ── Flash ── */
  function doFlash(col, op, dur) {
    flash.style.background = col || '#fff';
    flash.style.transition = 'none';
    flash.style.opacity = op || 0.9;
    setTimeout(function(){ flash.style.transition = 'opacity 0.12s'; flash.style.opacity = 0; }, dur || 80);
  }

  /* ── Phase state ── */
  var phase = 1, done = {}, t0 = performance.now(), raf;
  var pct = 0, pctIv, hexIv, statIv, ptIv;
  var stats = ['INITIALIZING...','ACCESSING SYSTEM...','DECRYPTING DATA...','BYPASSING FIREWALL...','LOADING ASSETS...','VERIFYING IDENTITY...','ACCESS GRANTED'];
  var si = 0;

  /* ── Phase 2: logo aparece ── */
  function p2() {
    if (done[2]) return; done[2] = 1; phase = 2;
    lw.style.transition = 'opacity 0.35s ease';
    lw.style.opacity = '1';
    setTimeout(function(){ sl.classList.add('on'); }, 250);
    setTimeout(function(){ lw.classList.add('chr'); }, 450);
    setTimeout(function(){ lw.classList.remove('chr'); }, 720);
    doFlash('#00FF41', 0.25, 100);
  }

  /* ── Phase 3: HUD hacking ── */
  function p3() {
    if (done[3]) return; done[3] = 1; phase = 3;
    sl.classList.remove('on');
    hudT.style.display = 'block';
    hudB.style.display = 'block';

    pctIv = setInterval(function(){
      pct = Math.min(100, pct + Math.floor(Math.random()*18)+3);
      pctEl.textContent = pct + '%';
      if (pct >= 100) {
        clearInterval(pctIv);
        pctEl.style.color = '#fff';
        pctEl.style.textShadow = '0 0 20px #fff, 0 0 40px #fff';
      }
    }, 65);

    hexIv = setInterval(function(){
      hexEl.textContent = '0x' + Math.floor(Math.random()*0xFFFFFF).toString(16).toUpperCase().padStart(6,'0')
        + '  ' + Math.floor(Math.random()*256).toString(2).padStart(8,'0');
    }, 55);

    statIv = setInterval(function(){
      if (si < stats.length) statEl.textContent = stats[si++];
      else clearInterval(statIv);
    }, 260);

    /* Glitch flickers */
    var gn = 0, gi = setInterval(function(){
      lw.classList.toggle('chr');
      if (++gn > 7) { clearInterval(gi); lw.classList.add('chr'); }
    }, 200);
  }

  /* ── Phase 4: zoom ── */
  function p4() {
    if (done[4]) return; done[4] = 1; phase = 4;
    clearInterval(pctIv); clearInterval(hexIv); clearInterval(statIv);
    hudT.style.display = 'none'; hudB.style.display = 'none';
    lw.classList.remove('chr'); lw.classList.add('chr-x');

    /* Calcular escala para llenar pantalla */
    var main = document.getElementById('clp-lg-main');
    var r    = main.getBoundingClientRect();
    var sc   = Math.max(innerWidth / (r.width || 80), innerHeight / (r.height || 80)) * 1.3;

    lw.style.transition = 'transform 1.9s cubic-bezier(0.22,0,0.9,1)';
    lw.style.transform  = 'scale(' + sc + ')';

    /* Destellos */
    [0, 350, 800, 1300].forEach(function(d){
      setTimeout(function(){ doFlash('#fff', 0.9, 90); }, d);
    });
    setTimeout(function(){ doFlash('#00FF41', 0.6, 60); }, 600);

    /* Partículas */
    ptIv = setInterval(function(){ spawnPts(10); }, 35);
    setTimeout(function(){ clearInterval(ptIv); }, 1900);

    /* Finalizar */
    setTimeout(function(){
      flash.style.background = '#fff';
      flash.style.transition = 'opacity 0.55s ease';
      flash.style.opacity    = '1';
      setTimeout(end, 480);
    }, 1900);
  }

  /* ── Fin ── */
  function end() {
    cancelAnimationFrame(raf);
    intro.style.transition = 'opacity 0.4s ease';
    intro.style.opacity    = '0';
    setTimeout(function(){ intro.remove(); sessionStorage.setItem('clp-intro','1'); }, 420);
  }

  /* ── Loop principal ── */
  function tick(now) {
    var e = (now - t0) / 1000;
    drawGrid();
    if (phase >= 4) drawPts();
    if (e >= 2) p2();
    if (e >= 3) p3();
    if (e >= 5) p4();
    raf = requestAnimationFrame(tick);
  }

  skip.addEventListener('click', end);
  raf = requestAnimationFrame(tick);
})();
</script>
{%- endunless -%}
