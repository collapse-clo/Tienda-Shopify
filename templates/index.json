    "collapse_faq": {
      "type": "collapse-faq",
      "settings": {
        "label": "FAQ",
        "heading": "Preguntas frecuentes",
        "q1": "¿Cuánto tarda el envío?",
        "a1": "Los pedidos se envían en 24-48h laborables para España peninsular. Recibirás un email de confirmación con el número de seguimiento.",
        "q2": "¿Puedo devolver una prenda?",
        "a2": "Sí. Tienes 14 días desde la recepción del pedido para devolver cualquier prenda sin usar y con las etiquetas originales.",
        "q3": "¿Hay restock de las prendas agotadas?",
